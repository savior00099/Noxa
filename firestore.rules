rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — profile doc, owner-only read/write
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // users/{uid}/addresses — owner-only
      match /addresses/{addressId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // users/{uid}/messages — owner can read/create; updates/deletes only via
      // the Admin SDK (server-side, used by the admin inbox reply route).
      match /messages/{messageId} {
        allow read, create: if request.auth != null && request.auth.uid == uid;
        allow update, delete: if false;
      }
    }

    // orders — a signed-in user can create their own order and read their own
    // orders. Status updates are admin-only (via the Admin SDK), never client-side.
    match /orders/{orderId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow update, delete: if false;
    }

    // reviews — anyone signed in can submit a review (starts unpublished).
    // Only published reviews are publicly readable. Moderation (publish/delete)
    // is admin-only, via the Admin SDK.
    match /reviews/{reviewId} {
      allow create: if request.auth != null;
      allow read: if resource.data.published == true;
      allow update, delete: if false;
    }
  }
}
